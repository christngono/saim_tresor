# ── Base de données ────────────────────────────────────────────────
DATABASE_URL="postgresql://saim:saim@localhost:5432/saim_treasury?schema=public"

# ── LLM : extraction de documents (OCR structuré) ──────────────────
# Principal : Together AI (Qwen2.5-VL) — extraction UNIQUEMENT, jamais de calcul
TOGETHER_API_KEY="sk-together-xxx"
TOGETHER_VISION_MODEL="Qwen/Qwen2.5-VL-72B-Instruct"
# Fallback extraction + génération de résumés en langage naturel
GROQ_API_KEY="gsk-xxx"
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Stockage fichiers (Cloudflare R2 — compatible S3) ──────────────
# En local, MinIO joue le rôle de R2 (voir infra/docker-compose.yml)
R2_ENDPOINT="http://localhost:9000"
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"
R2_BUCKET="saim-documents"
R2_REGION="auto"

# ── Auth (NextAuth v5) ─────────────────────────────────────────────
AUTH_SECRET="change-me-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── Backend ────────────────────────────────────────────────────────
API_BASE_URL="http://localhost:8000"
