{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": { "dependsOn": ["^build"], "outputs": [".next/**", "!.next/cache/**"] },
    "generate": { "cache": false },
    "migrate": { "cache": false },
    "rls": { "cache": false }
  }
}
